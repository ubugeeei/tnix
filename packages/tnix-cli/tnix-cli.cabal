cabal-version:      3.8
name:               tnix-cli
version:            0.1.0.0
build-type:         Simple
license:            MIT
license-file:       LICENSE
author:             tnix contributors
maintainer:         tnix@example.com
category:           Language
synopsis:           CLI for tnix

executable tnix
  main-is: Main.hs
  hs-source-dirs: app
  build-depends:
      base >=4.19 && <5
    , containers
    , optparse-applicative
    , text
    , tnix-core
  default-language: GHC2021
