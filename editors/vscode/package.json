{
  "name": "tnix",
  "version": "0.2.0",
  "publisher": "ubugeeei",
  "displayName": "tnix",
  "description": "Gradual typing support for Nix via tnix-lsp.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/tnix.git"
  },
  "homepage": "https://github.com/ubugeeei/tnix",
  "bugs": {
    "url": "https://github.com/ubugeeei/tnix/issues"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "nix",
    "lsp",
    "types",
    "gradual-typing"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "activationEvents": [
    "onLanguage:tnix"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tnix",
        "aliases": [
          "tnix"
        ],
        "extensions": [
          ".tnix",
          ".d.tnix"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "tnix",
      "properties": {
        "tnix.server.path": {
          "type": "string",
          "default": "tnix-lsp",
          "description": "Path to the tnix language server executable."
        },
        "tnix.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional command-line arguments passed to the tnix language server."
        },
        "tnix.server.cwd": {
          "type": "string",
          "default": "",
          "description": "Optional working directory used when starting the tnix language server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && ./node_modules/.bin/esbuild src/extension.ts --bundle --platform=node --format=esm --external:vscode --outfile=dist/extension.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test dist/*.spec.js",
    "fmt": "prettier --check src package.json tsconfig.json language-configuration.json README.md .vscodeignore",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.25.3",
    "ovsx": "^0.10.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
